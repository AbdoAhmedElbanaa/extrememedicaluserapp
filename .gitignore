# ==============================================================================
# Extreme Medical - Comprehensive and Professional Git Ignore Config
# ==============================================================================

# ------------------------------------------------------------------------------
# System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# IDEs and Text Editors
# ------------------------------------------------------------------------------
# JetBrains (IntelliJ IDEA, Android Studio, etc.)
.idea/
*.iml
*.ipr
*.iws
out/
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json
.history/
# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Flutter & Dart Exclusions
# ------------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/
/doc/api/
*.symbols
*.map.json

# ------------------------------------------------------------------------------
# Android Exclusions
# ------------------------------------------------------------------------------
.gradle/
local.properties
**/android/local.properties
**/android/key.properties
**/android/app/src/main/assets/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.apk
*.aab
*.ap_
*.jks
*.keystore
/android/app/debug/
/android/app/profile/
/android/app/release/

# ------------------------------------------------------------------------------
# iOS/macOS Exclusions
# ------------------------------------------------------------------------------
**/ios/Flutter/.last_build_id
**/ios/Flutter/ephemeral/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/
**/.xcworkspace/
**/*.xcworkspace/
**/*.xcuserstate
**/xcuserdata/
**/DerivedData/
*.mode1v3
*.mode2v3
*.perspectivev3

# ------------------------------------------------------------------------------
# Web Exclusions
# ------------------------------------------------------------------------------
**/web/flutter_bootstrap.js

# ------------------------------------------------------------------------------
# Local Configs, Logs & Temp Files
# ------------------------------------------------------------------------------
*.log
/tmp/
/temp/
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# PHP Dashboard & Uploads Exclusions
# ------------------------------------------------------------------------------
# Ignore all custom uploads but keep placeholder directory structures
/dashboard_php/uploads/*
!/dashboard_php/uploads/.gitkeep
/dashboard_php/config.local.php
/dashboard_php/.env
